{
  "name": "pro-dashboard",
  "version": "6.0.0",
  "private": true,
  "type": "module",
  "description": "An out-of-box UI solution for enterprise applications",
  "scripts": {
    "lint": "biome check --fix src",
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "deploy": "npm run build && npm run gh-pages",
    "dev": "npm run start",
    "gh-pages": "gh-pages -d dist",
    "openapi": "max openapi",
    "preview": "npm run build && max preview --port 8000",
    "record": "cross-env NODE_ENV=development REACT_APP_ENV=test max record --scene=login",
    "serve": "umi-serve",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none UMI_ENV=dev max dev",
    "start:pre": "cross-env REACT_APP_ENV=pre UMI_ENV=dev max dev",
    "start:test": "cross-env REACT_APP_ENV=test MOCK=none UMI_ENV=dev max dev",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:ui": "playwright test --ui-host=0.0.0.0",
    "e2e:report": "playwright show-report e2e-out/playwright-report",
    "prepare": "lefthook install",
    "postinstall": "max setup",
    "commit": "git add -A && git commit --no-edit",
    "squash": "bun scripts/squash.ts && git commit --no-edit --no-verify"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/pro-components": "^2.8.10",
    "@antv/l7": "^2.23.2",
    "@antv/l7-maps": "^2.23.2",
    "@antv/l7-react": "^2.4.3",
    "antd": "^6.3.1",
    "antd-style": "^4.1.0",
    "baseline-browser-mapping": "^2.10.0",
    "caniuse-lite": "^1.0.30001775",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "rc-util": "^5.44.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@dotenvx/dotenvx": "^1.52.0",
    "@es-proj/react": "^1.0.8",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@umijs/max": "^4.6.30",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "gh-pages": "^6.3.0",
    "git-cz": "^4.9.0",
    "knip": "^5.85.0",
    "lefthook": "^2.1.2",
    "react-dev-inspector": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "umi-presets-pro": "^2.0.3",
    "zod": "^4.3.6"
  }
}
